# ── Aditya-L1 Plasma Lab — Environment Variables ──────────────────────────
# Copy this file to `.env` and fill in your credentials.
# Never commit `.env` to version control.

# PRADAN portal credentials for accessing Aditya-L1 instrument data.
# Register at https://pradan.issdc.gov.in/
# Leave blank to run in simulation mode (realistic synthetic data).
PRADAN_EMAIL=
PRADAN_PASSWORD=
